# ─── Supabase (frontend, exposto no bundle — use a chave ANON, nunca a service_role) ───
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Scope CRM (somente servidor — usado pelas Vercel Functions em /api) ───
# Modo single-tenant: uma única chave da empresa para todo o deploy.
SCOPE_API_KEY=

# Modo multi-tenant (white-label): uma chave por empresa, referenciada por ?company=<slug>.
# O slug é convertido para MAIÚSCULAS e não-alfanuméricos viram "_".
# Ex.: ?company=acme  ->  SCOPE_API_KEY_ACME
# SCOPE_API_KEY_ACME=

# Base da API do Scope (opcional, só se mudar de ambiente)
# SCOPE_API_BASE=https://api.scopehub.com.br/api
