# ─── Supabase (frontend, exposto no bundle — use a chave ANON/PUBLISHABLE, nunca a service_role) ───
# Os valores de produção JÁ estão configurados no Vercel. Projeto: ovnryyojvsfuvwjfxvkr
VITE_SUPABASE_URL=https://ovnryyojvsfuvwjfxvkr.supabase.co
# Aceita a chave nova "sb_publishable_..." (equivalente à anon) ou uma anon JWT legada.
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# ─── Scope CRM (somente servidor — usado pelas Vercel Functions em /api) ───
# Multi-tenant (white-label): uma chave por empresa, referenciada por ?company=<slug>.
# O slug é convertido para MAIÚSCULAS e não-alfanuméricos viram "_". Ex.: ?company=effects -> SCOPE_API_KEY_EFFECTS
SCOPE_API_KEY_EFFECTS=

# Modo single-tenant: uma única chave da empresa para todo o deploy (não usado aqui).
# SCOPE_API_KEY=

# Base da API do Scope (opcional, só se mudar de ambiente)
# SCOPE_API_BASE=https://api.scopehub.com.br/api
